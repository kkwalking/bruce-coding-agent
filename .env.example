# 主聊天 LLM 配置读取自 ~/.bruce/setting.json。
# .env 仍用于 WebSearch、Embedding、MCP 环境变量替换等辅助配置。

# WebSearch 使用智谱 GLM_API_KEY，和主聊天 LLM 配置分开。
# GLM_API_KEY=your_glm_api_key_here
# GLM_SEARCH_ENGINE=search_std
# GLM_SEARCH_CONTENT_SIZE=medium

# 可选：切换搜索 Provider。
# WEB_SEARCH_PROVIDER=serpapi
# SERPAPI_KEY=your_serpapi_key_here
# WEB_SEARCH_PROVIDER=searxng
# SEARXNG_URL=http://localhost:8888

# RAG 默认使用本地 Ollama，也可按 Embedding 服务调整。
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_BASE_URL=http://localhost:11434
# EMBEDDING_API_KEY=

# 可选：覆盖默认的 ~/.bruce 数据目录。
# BRUCE_MEMORY_DIR=/path/to/memory
# BRUCE_RAG_DIR=/path/to/rag

# MCP 配置里的 ${GLM_API_KEY}、${HOME}、${PROJECT_DIR} 等变量会在启动时替换。
# 具体 server 配置写在 ~/.bruce/mcp.json 或项目内 .bruce/mcp.json。
